# Environment Variables — Link Graveyard Backend

# Node.js / NestJS
NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://user:pass@localhost:5439/link_graveyard
REDIS_HOST=localhost
REDIS_PORT=6380
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-refresh-in-production
INTERNAL_WORKER_SECRET=changeme-internal-secret
CORS_ORIGIN=http://localhost:3001

# Python Worker
CELERY_BROKER_URL=redis://localhost:6380/0
CELERY_RESULT_BACKEND=redis://localhost:6380/1
NESTJS_CALLBACK_URL=http://localhost:3000/api/v1/webhooks/worker/callback

# Third-party APIs
OPENAI_API_KEY=sk-...
GITHUB_TOKEN=ghp_...
SENTRY_DSN=https://...@sentry.io/...

# Push Notifications
FCM_SERVER_KEY=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=

# Monetization
AMAZON_AFFILIATE_TAG=
