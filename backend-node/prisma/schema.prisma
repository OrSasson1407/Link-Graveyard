generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar
  preferences  Json?    @default("{}")
  planType     String?  @default("FREE") @map("plan_type")
  timezone     String?  @default("UTC") @map("timezone") @db.VarChar(64)
  createdAt    DateTime @default(now()) @map("created_at")

  links        Link[]
  reminders    ReminderSchedule[]

  @@map("users")
}

model Link {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  originalUrl String    @map("original_url") @db.Text
  status      String    @default("PENDING") @db.VarChar(50)
  category    String?   @db.VarChar(50)
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  metadata    LinkMetadata?
  intent      UserIntent?
  reminders   ReminderSchedule[]

  @@index([userId, status])
  @@index([userId, originalUrl])
  @@map("links")
}

model LinkMetadata {
  linkId              String   @id @map("link_id") @db.Uuid
  title               String?  @db.VarChar(500)
  aiSummary           String?  @map("ai_summary") @db.Text
  previewImage        String?  @map("preview_image") @db.Text
  dynamicData         Json?    @default("{}") @map("dynamic_data")
  aiConfidence        Float?   @map("ai_confidence")
  readingTimeMinutes  Int?     @map("reading_time_minutes")

  link                Link     @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@map("link_metadata")
}

model UserIntent {
  id              String  @id @default(uuid()) @db.Uuid
  linkId          String  @unique @map("link_id") @db.Uuid
  source          String  @db.VarChar(100)
  inferredAction  String? @map("inferred_action") @db.VarChar(100)
  rawContext      String? @map("raw_context") @db.Text
  voiceTranscript String? @map("user_intent_voice_transcript") @db.Text

  link            Link    @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@map("user_intents")
}

model ReminderSchedule {
  id               String   @id @default(uuid()) @db.Uuid
  linkId           String   @map("link_id") @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  scheduledFor     DateTime @map("scheduled_for") @db.Timestamp()
  notificationSent Boolean  @default(false) @map("notification_sent")

  link             Link     @relation(fields: [linkId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reminders_schedule")
}